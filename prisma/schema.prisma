generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model Pais {
  id         Int         @id @default(autoincrement())
  nombre     String
  empleados  Empleado[]
  provincias Provincia[]
}

model Provincia {
  id        Int        @id @default(autoincrement())
  nombre    String
  idPais    Int
  empleados Empleado[]
  pais      Pais       @relation(fields: [idPais], references: [id], onUpdate: NoAction)
}

model Area {
  id        Int        @id @default(autoincrement())
  nombre    String
  empleados Empleado[]
}

model Idioma {
  id              Int              @id @default(autoincrement())
  nombre          String
  empleadoIdiomas EmpleadoIdioma[]
}

model NivelEducativo {
  id                Int                 @id @default(autoincrement())
  nombre            String
  empleadoEducacion EmpleadoEducacion[]
}

model TipoConvenio {
  id          Int         @id @default(autoincrement())
  nombre      String
  empleados   Empleado[]
  habilidades Habilidad[]
}

model Habilidad {
  id                  Int                 @id @default(autoincrement())
  nombre              String
  idTipoConvenio      Int
  empleadoHabilidades EmpleadoHabilidad[]
  tipoConvenio        TipoConvenio        @relation(fields: [idTipoConvenio], references: [id], onUpdate: NoAction)
}

model Herramienta {
  id                   Int                   @id @default(autoincrement())
  nombre               String
  empleadoHerramientas EmpleadoHerramienta[]
}

model Licencia {
  id                Int                @id @default(autoincrement())
  codigo            String
  nombre            String
  empleadoLicencias EmpleadoLicencia[]
}

model Empleado {
  id                    Int                     @id @default(autoincrement())
  nombre                String
  dni                   String
  telefono              String
  email                 String
  urlCv                 String
  idProvincia           Int
  idPais                Int
  idTipoConvenio        Int?
  idArea                Int?
  puesto                String?
  idPuesto              Int?
  idDisponibilidadViaje Int
  createdAt             DateTime                @default(now())
  fechaNacimiento       DateTime?               @db.Date
  idEstadoEmpleado      Int?
  area                  Area?                   @relation(fields: [idArea], references: [id], onDelete: NoAction, onUpdate: NoAction)
  disponibilidad        DisponibilidadViaje     @relation(fields: [idDisponibilidadViaje], references: [id], onUpdate: NoAction)
  pais                  Pais                    @relation(fields: [idPais], references: [id], onUpdate: NoAction)
  provincia             Provincia               @relation(fields: [idProvincia], references: [id], onUpdate: NoAction)
  tipoConvenio          TipoConvenio?           @relation(fields: [idTipoConvenio], references: [id], onDelete: NoAction, onUpdate: NoAction)
  puestoRef             Puesto?                 @relation(fields: [idPuesto], references: [id], onDelete: NoAction, onUpdate: NoAction)
  EstadoEmpleado        EstadoEmpleado?         @relation(fields: [idEstadoEmpleado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Empleado_EstadoEmpleado")
  certificaciones       EmpleadoCertificacion[]
  educacion             EmpleadoEducacion[]
  experiencias          EmpleadoExperiencia[]
  habilidades           EmpleadoHabilidad[]
  herramientas          EmpleadoHerramienta[]
  idiomas               EmpleadoIdioma[]
  licencias             EmpleadoLicencia[]

  @@index([idEstadoEmpleado], map: "IX_Empleado_idEstadoEmpleado")
}

model EmpleadoExperiencia {
  id          Int       @id @default(autoincrement())
  empresa     String
  puesto      String
  rubro       String
  desde       DateTime
  hasta       DateTime?
  descripcion String
  idEmpleado  Int
  empleado    Empleado  @relation(fields: [idEmpleado], references: [id], onUpdate: NoAction)
}

model EmpleadoEducacion {
  id               Int            @id @default(autoincrement())
  titulo           String
  institucion      String
  inicio           Int
  final            Int?
  idNivelEducativo Int
  idEmpleado       Int
  empleado         Empleado       @relation(fields: [idEmpleado], references: [id], onUpdate: NoAction)
  nivelEducativo   NivelEducativo @relation(fields: [idNivelEducativo], references: [id], onUpdate: NoAction)
}

model EmpleadoCertificacion {
  id         Int      @id @default(autoincrement())
  nombre     String
  idEmpleado Int
  empleado   Empleado @relation(fields: [idEmpleado], references: [id], onUpdate: NoAction)
}

model EmpleadoIdioma {
  id         Int      @id @default(autoincrement())
  idEmpleado Int
  idIdioma   Int
  empleado   Empleado @relation(fields: [idEmpleado], references: [id], onUpdate: NoAction)
  idioma     Idioma   @relation(fields: [idIdioma], references: [id], onUpdate: NoAction)
}

model EmpleadoHabilidad {
  id          Int       @id @default(autoincrement())
  idEmpleado  Int
  idHabilidad Int
  empleado    Empleado  @relation(fields: [idEmpleado], references: [id], onUpdate: NoAction)
  habilidad   Habilidad @relation(fields: [idHabilidad], references: [id], onUpdate: NoAction)
}

model EmpleadoHerramienta {
  id            Int         @id @default(autoincrement())
  idEmpleado    Int
  idHerramienta Int
  empleado      Empleado    @relation(fields: [idEmpleado], references: [id], onUpdate: NoAction)
  herramienta   Herramienta @relation(fields: [idHerramienta], references: [id], onUpdate: NoAction)
}

model EmpleadoLicencia {
  id         Int      @id @default(autoincrement())
  idEmpleado Int
  idLicencia Int
  empleado   Empleado @relation(fields: [idEmpleado], references: [id], onUpdate: NoAction)
  licencia   Licencia @relation(fields: [idLicencia], references: [id], onUpdate: NoAction)
}

model DisponibilidadViaje {
  id        Int        @id @default(autoincrement())
  nombre    String
  empleados Empleado[]
}

model Puesto {
  id        Int        @id @default(autoincrement())
  nombre    String
  empleados Empleado[]
}

model EstadoEmpleado {
  id       Int        @id(map: "PK_EstadoEmpleado") @default(autoincrement())
  nombre   String
  Empleado Empleado[]
}

model sysdiagrams {
  name         String @db.NVarChar(128)
  principal_id Int
  diagram_id   Int    @id(map: "PK__sysdiagr__C2B05B6134E1CED3") @default(autoincrement())
  version      Int?
  definition   Bytes?

  @@unique([principal_id, name], map: "UK_principal_name")
}
